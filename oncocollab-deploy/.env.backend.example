# ============================================================
# .env.backend — Configuration API NestJS
# Copier ce fichier en .env.backend et remplir les valeurs
# ============================================================

PORT=3002
USE_HTTPS=false

# Adresse IP publique du serveur (pour les WebSockets)
EXTERNAL_IP=127.0.0.1

# PostgreSQL — doit correspondre à .env.postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=oncocollab
POSTGRES_PASSWORD=mot_de_passe_postgres_a_choisir
POSTGRES_DB=oncocollab

# MongoDB (géré automatiquement par Docker)
MONGODB_URI=mongodb://mongo:27017/oncocollab_prerequisites

# JWT — générer une clé aléatoire forte
# Exemple Linux/Mac : openssl rand -hex 64
JWT_SECRET=remplacer_par_une_cle_aleatoire_tres_longue

# Supabase — récupérer depuis votre dashboard Supabase
# https://app.supabase.com → Settings → API
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_ANON_KEY=votre_supabase_anon_key
SUPABASE_SERVICE_KEY=votre_supabase_service_key

# TURN Server WebRTC — doit correspondre à .env
TURN_URL=turn:127.0.0.1:3478?transport=udp
TURN_USERNAME=oncocollab
TURN_PASSWORD=mot_de_passe_turn_a_choisir

# ─── Génération de rapports RCP ────────────────────────────
# Ces variables sont overridées par docker-compose (voir docker-compose.yml)
# mais doivent être présentes pour les builds sans Docker
PIPELINE_URL=http://python-pipeline:8000
GEMINI_API_KEY=votre_cle_gemini_api
GEMINI_MODEL=gemini-2.5-flash
WHISPER_MODEL=base

# Qdrant — base vectorielle pour la recherche sémantique
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=oncocollab_reports

# Stockage PDF des rapports
SUPABASE_REPORTS_BUCKET=meeting-reports
LOCAL_REPORTS_DIR=/data/reports

# Olga API — formulaires dynamiques (overridé par docker-compose)
OLGA_BASE_URL=http://olga-api:9091
