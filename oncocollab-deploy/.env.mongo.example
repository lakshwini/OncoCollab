# ============================================================
# .env.mongo — Configuration MongoDB
# Copier ce fichier en .env.mongo
# MongoDB est utilisé sans authentification (usage interne uniquement)
# ============================================================

# Laisser vide pour un accès sans authentification (recommandé en local)
# En production, ajouter :
# MONGO_INITDB_ROOT_USERNAME=oncocollab
# MONGO_INITDB_ROOT_PASSWORD=mot_de_passe_mongo
