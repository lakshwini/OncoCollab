# ============================================================
# olga-designer/.env.back — Configuration Olga API (Spring Boot)
# Copier ce fichier en .env.back et remplir les valeurs
# ⚠️ Ces valeurs doivent correspondre à olga-designer/.env.mysql
# ============================================================

# Spring Boot DataSource (MySQL — doit correspondre à olga-designer/.env.mysql)
# Note: le service MySQL est accessible via l'alias 'mysql' dans le réseau olga
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/olga?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=olga_user
SPRING_DATASOURCE_PASSWORD=mot_de_passe_mysql_a_choisir

ADDRESS=0.0.0.0
PORT=9091
FIREBASE_KEY_PATH=/app/config/apiKey.json
