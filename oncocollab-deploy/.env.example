# ============================================================
# .env — Configuration globale OncoCollab
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# Votre IP publique (pour WebRTC TURN server)
# En local : laisser 127.0.0.1
# En production : mettre votre vraie IP publique
EXTERNAL_IP=127.0.0.1

# Identifiants du TURN server (choisir librement)
TURN_USERNAME=oncocollab
TURN_PASSWORD=mot_de_passe_turn_a_choisir

# ⚠️ Votre nom d'utilisateur Docker Hub
# Les images seront téléchargées depuis : DOCKER_REGISTRY/oncocollab-frontend:latest
DOCKER_REGISTRY=votre_username_docker_hub

# ─── Génération de rapports RCP (Whisper + Gemini) ─────────
# Clé API Google Gemini — https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=votre_cle_gemini_api

# Modèle Gemini (gemini-2.5-flash recommandé, gemini-1.5-flash si quota limité)
GEMINI_MODEL=gemini-2.5-flash

# Modèle Whisper (tiny/base/small/medium/large — base recommandé)
WHISPER_MODEL=base
