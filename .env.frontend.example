# Frontend (React / Vite) — copier en .env.frontend et remplir les valeurs
# Ne jamais committer .env.frontend

VITE_API_URL=http://localhost:3002
VITE_WS_URL=ws://localhost:3002
VITE_USE_HTTPS=false

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

VITE_TURN_URL=turn:your.server.ip:3478
VITE_TURN_USERNAME=your_turn_username
VITE_TURN_PASSWORD=your_turn_password
