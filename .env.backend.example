# Backend (NestJS) — copier en .env.backend et remplir les valeurs
# Ne jamais committer .env.backend

PORT=3002
USE_HTTPS=false
EXTERNAL_IP=your.public.ip

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=OncoCollab

MONGODB_URI=mongodb://mongo:27017/oncocollab_prerequisites

JWT_SECRET=generate-a-strong-random-secret-here

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

TURN_URL=turn:your.public.ip:3478?transport=udp
TURN_USERNAME=your_turn_username
TURN_PASSWORD=your_turn_password
