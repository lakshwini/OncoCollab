# Backend (NestJS) — copier en .env.backend et remplir les valeurs
# Ne jamais committer .env.backend

PORT=3002
USE_HTTPS=false
EXTERNAL_IP=your.public.ip

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=OncoCollab

MONGODB_URI=mongodb://mongo:27017/oncocollab_prerequisites

JWT_SECRET=generate-a-strong-random-secret-here

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

TURN_URL=turn:your.public.ip:3478?transport=udp
TURN_USERNAME=your_turn_username
TURN_PASSWORD=your_turn_password

# ──────────────────────────────────────────
# Génération de rapport RCP (Whisper + Gemini + Qdrant)
# ──────────────────────────────────────────
# Clé API Google Gemini (obligatoire pour la génération de rapports)
# Obtenir une clé : https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=your_gemini_api_key

# Modèle Gemini (gemini-1.5-flash = rapide+gratuit, gemini-1.5-pro = meilleure qualité)
GEMINI_MODEL=gemini-1.5-flash

# Modèle Whisper (tiny|base|small|medium|large) — base = bon compromis
WHISPER_MODEL=base

# URL du microservice Python (réseau Docker interne)
PIPELINE_URL=http://python-pipeline:8000

# Qdrant (vectoriel, recherche sémantique sur les rapports)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=oncocollab_reports

# Bucket Supabase pour stocker les PDF (sera créé automatiquement)
SUPABASE_REPORTS_BUCKET=meeting-reports
