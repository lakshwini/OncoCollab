# Olga API (Spring Boot) — copier en .env.back et remplir les valeurs
# Ne jamais committer .env.back

# Spring Boot DataSource (MySQL — doit correspondre à .env.mysql)
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/olga?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=your_mysql_user
SPRING_DATASOURCE_PASSWORD=your_mysql_password

ADDRESS=0.0.0.0
PORT=9091
FIREBASE_KEY_PATH=/app/config/apiKey.json
